# `ghibli` 只讀 **專案本地** 的 .env（不往上找 ~/.env），且無 silent default model。
# 首次啟動時若所有 provider 都缺 key，picker 顯示 5 選項（Gemini API Key /
# Gemini Vertex AI / Gemma-4 / OpenAI / Ollama Cloud）並進 onboarding：
# 選 model → 貼 API key（隱藏輸入，或 Vertex 路徑 prompt project id）
# → 自動 append 到本檔案，然後進對話。
# 也可以手動填下面的 key 跳過 onboarding。

# --- Gemini 認證（二擇一）---

# Option 1: API Key 模式
# 至 https://aistudio.google.com/app/apikey 取得 API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Option 2: Vertex AI 模式（需搭配 Google ADC）
# 先執行 `gcloud auth application-default login`
GOOGLE_CLOUD_PROJECT=your_gcp_project_id

# Vertex AI 模式選用，預設 us-central1
GOOGLE_CLOUD_LOCATION=us-central1

# 選用，提高 GitHub API rate limit 至 5000 req/hr
# 至 https://github.com/settings/tokens 建立 PAT（只需 public_repo read 權限）
GITHUB_TOKEN=your_github_pat_here

# CLI 使用的模型（預設 gemini-2.5-flash）
#   - 預設 / 其他字串 → Gemini 原生 SDK（API Key 或 Vertex AI）
#   - openai:<model>  → OpenAI via LiteLLM，例如 openai:gpt-4o-mini（需 OPENAI_API_KEY）
#   - ollama:<slug>   → Ollama Cloud via LiteLLM，例如 ollama:llama3.1:8b（需 OLLAMA_API_KEY）
# GHIBLI_MODEL=gemini-2.5-flash

# OpenAI API key（CLI 用 GHIBLI_MODEL=openai:... 時必填；eval --model gpt4o-mini 也需要）
OPENAI_API_KEY=

# OpenAI 用哪個 model（picker 選 OpenAI 時會套用；預設 gpt-4o-mini）
# 完整可用清單：https://developers.openai.com/api/docs/models/all
# OPENAI_MODEL=gpt-4o-mini

# Ollama Cloud（CLI 用 GHIBLI_MODEL=ollama:... 時必填；eval --model ollama-cloud 也需要）
# 取得 key：https://ollama.com/settings/keys
OLLAMA_API_KEY=

# Model to use for Ollama Cloud (default: qwen3.5:cloud)
OLLAMA_CLOUD_MODEL=qwen3.5:cloud
