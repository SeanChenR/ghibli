# --- Gemini 認證（二擇一）---

# Option 1: API Key 模式
# 至 https://aistudio.google.com/app/apikey 取得 API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Option 2: Vertex AI 模式（需搭配 Google ADC）
# 先執行 `gcloud auth application-default login`
GOOGLE_CLOUD_PROJECT=your_gcp_project_id

# Vertex AI 模式選用，預設 us-central1
GOOGLE_CLOUD_LOCATION=us-central1

# 選用，提高 GitHub API rate limit 至 5000 req/hr
# 至 https://github.com/settings/tokens 建立 PAT（只需 public_repo read 權限）
GITHUB_TOKEN=your_github_pat_here

# CLI 使用的 Gemini 模型（預設 gemini-2.5-flash，可改為其他 Gemini 模型）
# GHIBLI_MODEL=gemini-2.5-flash

# OpenAI API key (required for gpt4o-mini eval)
OPENAI_API_KEY=

# Ollama Cloud (required for ollama-cloud eval and GHIBLI_MODEL=ollama:<model>)
# Get your key at https://ollama.com/settings/keys
OLLAMA_API_KEY=
# Model to use for Ollama Cloud (default: llama3.1:8b)
# OLLAMA_CLOUD_MODEL=llama3.1:8b
